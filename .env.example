# =============================================================================
# BPM / Playwright 測試環境變數
# =============================================================================

# --- BPM 站台與登入 ---
# BPM 首頁/導頁（請保留原本的 query/路徑結構）
BPM_BASE_URL="https://efgp.yuchens.com:8086/NaNaWeb/GP//ForwardIndex?hdnMethod=findIndexForward"

# 測試用帳號密碼（建議用引號包住特殊字元）
PLAYWRIGHT_BPM_USER="boyawu"
PLAYWRIGHT_BPM_PASSWORD=""

# --- 測試行為開關/安全閥 ---
# 分頁迴圈上限（避免 UI 異常時無限循環）
BPM_MAX_PAGES="100"

# 是否真的點擊「退回重辦」
BPM_ENABLE_REEXECUTE="true"

# 退回重辦類型（當彈窗同時有兩個 radio 時使用）
# 允許值：0/prev（退回前一關） | 2/first（退回第一關）
BPM_REEXECUTE_TYPE="0"

# --- 測試資料/目標條件（workitemCheck） ---
# 指定專案代碼（可留空代表不限制）
BPM_TARGET_PROJECT_CODE="DY23-0742"

# 簽核/提示用文字（用於摘要或 UI 可視性）
BPM_APPROVAL_COMMENT="請補上 WorkItem。"
